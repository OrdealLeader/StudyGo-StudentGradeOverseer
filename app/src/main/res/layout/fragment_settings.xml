<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true"
    tools:context=".SettingsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header Section -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/header_blue_bg"
            android:padding="24dp"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:id="@+id/profileImageContainer"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@drawable/profile_box_bg"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/noto_sans_bold"
                    android:text="@string/profile_initials"
                    android:textColor="@color/accent_blue"
                    android:textSize="36sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/userName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:fontFamily="@font/noto_sans_bold"
                android:text="@string/user_full_name"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:lineSpacingExtra="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/profileImageContainer"
                app:layout_constraintTop_toTopOf="@id/profileImageContainer" />

            <TextView
                android:id="@+id/universityName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/noto_sans"
                android:text="@string/university_name"
                android:textColor="@color/light_blue_text"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/userName"
                app:layout_constraintTop_toBottomOf="@id/userName" />

            <TextView
                android:id="@+id/yearLevel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/noto_sans"
                android:text="@string/year_level"
                android:textColor="@color/accent_blue"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/userName"
                app:layout_constraintTop_toBottomOf="@id/universityName" />

            <TextView
                android:id="@+id/courseBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/badge_pill_bg"
                android:fontFamily="@font/noto_sans_bold"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:text="@string/course_name"
                android:textColor="@color/accent_blue"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@id/userName"
                app:layout_constraintTop_toBottomOf="@id/yearLevel" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Rest of the settings content can go here -->

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>