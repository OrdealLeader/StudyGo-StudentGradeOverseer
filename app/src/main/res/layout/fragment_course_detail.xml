<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true"
    tools:context=".CourseDetailFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/courseTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/noto_sans_bold"
            android:text="Design and Analysis of Algorithms"
            android:textColor="@color/white"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Grade Summary Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/gradeSummaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/courseTitle">

            <TextView
                android:id="@+id/currentGradeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Grade"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/currentGradeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3.0"
                android:textColor="@color/success_green"
                android:textSize="36sp"
                android:fontFamily="@font/noto_sans_bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/currentGradeLabel" />

            <View
                android:id="@+id/divider"
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="24dp"
                android:background="@color/text_gray"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/targetGradeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target Grade"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                app:layout_constraintStart_toEndOf="@id/divider"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/targetGradeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.0"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:fontFamily="@font/noto_sans_bold"
                app:layout_constraintStart_toEndOf="@id/divider"
                app:layout_constraintTop_toBottomOf="@id/targetGradeLabel" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/requirementsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/noto_sans_bold"
            android:text="School Requirements"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/gradeSummaryCard" />

        <!-- Example Requirement 1 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/reqCard1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/requirementsTitle">

            <TextView
                android:id="@+id/reqName1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Midterm Quiz"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/noto_sans_bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/reqWeight1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weight: 20%"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/reqName1" />

            <TextView
                android:id="@+id/reqScore1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="95/100"
                android:textColor="@color/success_green"
                android:textSize="18sp"
                android:fontFamily="@font/noto_sans_bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>