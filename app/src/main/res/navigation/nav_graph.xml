<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/FirstFragment">

    <action
        android:id="@+id/action_global_FirstFragment"
        app:destination="@id/FirstFragment"
        app:popUpTo="@id/nav_graph"
        app:popUpToInclusive="true" />

    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.example.studygo_studentgradeoverseer.LoginFragment"
        android:label="@string/first_fragment_label"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_FirstFragment_to_dashboard"
            app:destination="@id/dashboard"
            app:popUpTo="@id/FirstFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_FirstFragment_to_SignUpFragment"
            app:destination="@id/SignUpFragment" />
    </fragment>

    <fragment
        android:id="@+id/SignUpFragment"
        android:name="com.example.studygo_studentgradeoverseer.SignUpFragment"
        android:label="Sign Up"
        tools:layout="@layout/fragment_sign_up">
        <action
            android:id="@+id/action_SignUpFragment_to_dashboard"
            app:destination="@id/dashboard"
            app:popUpTo="@id/FirstFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/dashboard"
        android:name="com.example.studygo_studentgradeoverseer.DashboardFragment"
        android:label="@string/second_fragment_label"
        tools:layout="@layout/fragment_dashboard">

        <action
            android:id="@+id/action_dashboard_to_FirstFragment"
            app:destination="@id/FirstFragment" />

        <action
            android:id="@+id/action_dashboard_to_courseInputFragment"
            app:destination="@id/courseInputFragment" />

        <action
            android:id="@+id/action_dashboard_to_courseDetailFragment"
            app:destination="@id/courseDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/courseInputFragment"
        android:name="com.example.studygo_studentgradeoverseer.CourseInputFragment"
        android:label="Add Course"
        tools:layout="@layout/fragment_course_input">

        <action
            android:id="@+id/action_courseInputFragment_to_courseDetailFragment"
            app:destination="@id/courseDetailFragment"
            app:popUpTo="@id/courseInputFragment"
            app:popUpToInclusive="true" />

        <argument
            android:name="courseId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/courseDetailFragment"
        android:name="com.example.studygo_studentgradeoverseer.CourseDetailFragment"
        android:label="Course Detail"
        tools:layout="@layout/fragment_course_detail">
        <argument
            android:name="courseId"
            app:argType="string" />

        <action
            android:id="@+id/action_courseDetailFragment_to_taskInputFragment"
            app:destination="@id/taskInputFragment" />
        <action
            android:id="@+id/action_courseDetailFragment_to_taskEditFragment"
            app:destination="@id/taskEditFragment" />
        <action
            android:id="@+id/action_courseDetailFragment_to_courseInputFragment"
            app:destination="@id/courseInputFragment" />
    </fragment>

    <fragment
        android:id="@+id/taskInputFragment"
        android:name="com.example.studygo_studentgradeoverseer.TaskInputFragment"
        android:label="Task Input"
        tools:layout="@layout/fragment_task_input">
        <argument
            android:name="courseId"
            app:argType="string" />
        <argument
            android:name="categoryName"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/taskEditFragment"
        android:name="com.example.studygo_studentgradeoverseer.TaskEditFragment"
        android:label="Edit Task"
        tools:layout="@layout/fragment_task_edit">
        <argument
            android:name="courseId"
            app:argType="string" />
        <argument
            android:name="categoryName"
            app:argType="string" />
        <argument
            android:name="taskId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/SimulatorFragment"
        android:name="com.example.studygo_studentgradeoverseer.SimulatorFragment"
        android:label="Simulator"
        tools:layout="@layout/fragment_simulator">
    </fragment>

    <fragment
        android:id="@+id/ResultsFragment"
        android:name="com.example.studygo_studentgradeoverseer.ResultsFragment"
        android:label="Results"
        tools:layout="@layout/fragment_settings">
    </fragment>

    <fragment
        android:id="@+id/SettingsFragment"
        android:name="com.example.studygo_studentgradeoverseer.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_SettingsFragment_to_SignUpFragment"
            app:destination="@id/SignUpFragment" />
    </fragment>
</navigation>
